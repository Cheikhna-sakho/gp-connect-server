# DB Config
HOST=localhost
DATABASE_PASSWORD=db_passord
DATABASE_USER=db_user
DATABASE_PORT=db_port
DATABASE=db_name
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${HOST}:${DATABASE_PORT}/${DATABASE}
SHADOW_DATABASE=shadow_db_name
SHADOW_DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${HOST}:${DATABASE_PORT}/${SHADOW_DATABASE}
# Environment
NODE_ENV=development
PORT=5000
#Cloudinary
CLOUDINARY_NAME=API_NAME
CLOUDINARY_API_KEY=API_KEY
CLOUDINARY_API_SECRET=API_SECRET
CLOUDINARY_URL=cloudinary://${CLOUDINARY_API_KEY}:{CLOUDINARY_API_SECRET}@${CLOUDINARY_NAME}
en fait je peux me service de la table mission avec plus de potentiel que d'etre simplement utilisé comme une annonces d'utilisateur, en enlevant la contrainte unique sur le champ advertisementId, je peux gerer les colis lier a une annonces et niveau logique du code je peux empecher le duplicat si il s'agit d'un annonce utilisateur

ACCESS_TOKEN_EXP="5min"
REFRESH_TOKEN_EXP="7d"

