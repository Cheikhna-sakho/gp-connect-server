// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://majid:majid@localhost:5432/mydb"
}
model Utilisateur {
  id       Int      @id @default(autoincrement())
  nom      String
  email    String   @unique
  age      Int?
}