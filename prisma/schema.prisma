generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SHIPPER @map("shipper")
  ADMIN   @map("admin")
  CARRIER @map("carrier")
}

enum TransactionMethod {
  CASH        @map("cash")
  CREDIT_CARD @map("credit_card")
  PAYPAL      @map("paypal")
}

enum TransactionStatus {
  PENDING   @map("pending")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
}

enum PackageStatus {
  PENDING    @map("pending")
  PICKED_UP  @map("picked_up")
  IN_TRANSIT @map("in_transit")
  DISPUTED   @map("disputed")
  DELIVERED  @map("delivered")
}

enum MissionStatus {
  PENDING    @map("pending")
  ACCEPTED   @map("accepted")
  IN_TRANSIT @map("in_transit") // colis récupéré par le carrier, en cours de transport
  COMPLETED  @map("completed")
  CANCELLED  @map("canceled")
  DISPUTED   @map("disputed")
}

enum AdvertisementType {
  SHIPPING @map("shipping")
  DELIVERY @map("delivery")
}

enum AdvertisementStatus {
  OPEN        @map("open")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  CLOSED      @map("closed")
}

enum ConversationStatus {
  DRAFT    @map("draft")
  ARCHIVED @map("archived")
  ACTIVE   @map("active")
}

enum MessageOfferStatus {
  PENDING  @map("pending")
  REJECTED @map("rejected")
  ACCEPTED @map("accepted")
  // DEAL @map("deal") /* comment car faudra reflechir si veux un system de confirmation apres acceptation  traquer q*/
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  phone     String? @unique
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  password  String?
  role      Role    @default(SHIPPER)

  //  VERIFY
  emailVerifiedAt  DateTime? @map("email_verified_at")
  phoneVerifiedAt  DateTime? @map("phone_verified_at")
  idCardVerifiedAt DateTime? @map("id_card_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  advertisements         Advertisement[]
  packages               Package[]
  missions               Mission[]           @relation("Initiator")
  acceptedMissions       Mission[]           @relation("Acceptor")
  messages               Message[]           @relation("sender")
  ConversationsAsShipper Conversation[]      @relation("shipper")
  ConversationsAsCarrier Conversation[]      @relation("carrier")
  avatar                 UserAvatar?
  initiateProof          MissionProof[]      @relation("ProofCreatedBy")
  verifiedProof          MissionProof[]      @relation("ProofVerifiedBy")
  tokens                 VerificationToken[]
  identities             UserIdentity[]
  providers              UserProvider[]
  preferences            UserPreferences?
  savedAddresses         SavedAddress[]
  ratingsGiven           MissionRating[]     @relation("RatingGiven")
  ratingsReceived        MissionRating[]     @relation("RatingReceived")
  openedDisputes         MissionDispute[]    @relation("DisputeOpened")
  resolvedDisputes       MissionDispute[]    @relation("DisputeResolved")

  @@map("users")
}

model UserAvatar {
  userId  String @unique @map("user_id")
  imageId String @map("image_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  image Media @relation(fields: [imageId], references: [id])

  @@id([userId, imageId])
  @@map("user_avatar")
}

enum UserIdentityStatus {
  PENDING        @map("pending")
  VERIFIED       @map("verified")
  REJECTED       @map("rejected")
  REQUIRES_INPUT @map("requires_input")
  CANCELED       @map("canceled")
}

enum UserIdentityProvider {
  STRIPE_IDENTITY @map("stripe_identity")
}

model UserIdentity {
  provider   UserIdentityProvider
  providerId String               @map("provider_id")
  status     UserIdentityStatus
  userId     String               @map("user_id")
  reason     String?
  expiredAt  DateTime?            @map("expired_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1 user x 1 provider max
  @@unique([userId, provider])
  // providerId unique côté provider
  @@unique([provider, providerId])
  @@map("user_identities")
}

enum AuthProvider {
  GOOGLE   @map("google")
  APPLE    @map("apple")
  FACEBOOK @map("facebook")
}

model UserProvider {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  email          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@map("user_providers")
}

enum VerificationTokenType {
  EMAIL @map("email")
  PHONE @map("phone")
}

model VerificationToken {
  id        String                @id @default(uuid())
  userId    String                @map("user_id")
  type      VerificationTokenType
  tokenHash String                @map("token_hash")
  expiresAt DateTime              @map("expires_at")
  usedAt    DateTime?             @map("used_at")
  createdAt DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("verification_tokens")
}

model Address {
  id        String   @id @default(uuid())
  street    String?
  zipCode   String?  @map("zip_code")
  cityId    String   @map("city_id")
  latitude  Decimal? @db.Decimal(8, 6)
  longitude Decimal? @db.Decimal(9, 6)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city         City            @relation(fields: [cityId], references: [id])
  destinations Advertisement[] @relation("destination")
  departures   Advertisement[] @relation("departure")
  savedBy      SavedAddress[]

  @@unique([latitude, longitude])
  @@map("addresses")
}

model City {
  id             String @id @default(uuid())
  name           String
  countryIsoCode String @map("country_iso_code")
  country        String

  addresses Address[]

  @@unique([name, countryIsoCode])
  @@map("cities")
}

enum MediaType {
  IMAGE @map("image")
  AUDIO @map("audio")
  VIDEO @map("video")
}

model Media {
  id        String    @id @default(uuid())
  url       String
  publicId  String?   @map("public_id")
  type      MediaType
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  packages      PackageMedia[]
  messages      MessageMedia[]
  userAvatar    UserAvatar[]
  missionProofs MissionProofImage[]

  @@map("medias")
}

model Package {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      PackageStatus @default(PENDING)
  weight      Decimal       @default(0) @db.Decimal(7, 3)
  ownerId     String        @map("owner_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  owner         User              @relation(fields: [ownerId], references: [id])
  images        PackageMedia[]
  mission       MissionPackage[]
  @@map("packages")
}

model PackageMedia {
  packageId String   @map("package_id")
  mediaId   String   @map("media_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([packageId, mediaId])
  @@map("package_medias")
}

model Mission {
  id              String        @id @default(uuid())
  advertisementId String        @map("advertisement_id")
  shipperId       String        @map("shipper_id")
  carrierId       String?       @map("carrier_id")
  negotiatedPrice Decimal       @default(0) @map("negotiated_price")
  status          MissionStatus @default(PENDING)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  shipper        User             @relation("Initiator", fields: [shipperId], references: [id])
  carrier       User?            @relation("Acceptor", fields: [carrierId], references: [id])
  advertisement Advertisement    @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  transaction   Transaction?
  packages      MissionPackage[]
  offers        MessageOffer[]
  proofs        MissionProof[]
  conversations Conversation[]
  ratings       MissionRating[]
  dispute       MissionDispute?

  @@map("missions")
}

enum DisputeStatus {
  OPEN     @map("open")
  RESOLVED @map("resolved")
}

model MissionDispute {
  id           String        @id @default(uuid())
  missionId    String        @unique @map("mission_id")
  openedById   String        @map("opened_by_id")
  reason       String
  description  String?
  status       DisputeStatus @default(OPEN)
  resolution   String?
  resolvedById String?       @map("resolved_by_id")
  resolvedAt   DateTime?     @map("resolved_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  mission    Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  openedBy   User    @relation("DisputeOpened", fields: [openedById], references: [id])
  resolvedBy User?   @relation("DisputeResolved", fields: [resolvedById], references: [id])

  @@map("mission_disputes")
}

model MissionPackage {
  missionId String @map("missionId")
  packageId String @map("package_id")

  package Package @relation(fields: [packageId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@id([missionId, packageId])
  @@map("mission_packages")
}

enum ProofType {
  PICKUP
  DELIVERY
  OTHER
}

model MissionProof {
  id        String    @id @default(uuid())
  missionId String    @map("mission_id")
  type      ProofType

  otpHash      String?   @map("otp_hash")
  otpExpiresAt DateTime? @map("otp_expires_at")
  otpUsedAt    DateTime? @map("otp_used_at")

  createdById  String? @map("created_by_id")
  verifiedById String? @map("verified_by_id")

  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  mission    Mission             @relation(fields: [missionId], references: [id], onDelete: Cascade)
  createdBy  User?               @relation("ProofCreatedBy", fields: [createdById], references: [id])
  verifiedBy User?               @relation("ProofVerifiedBy", fields: [verifiedById], references: [id])
  images     MissionProofImage[]

  @@unique([missionId, type])
  @@index([missionId])
  @@map("delivery_proofs")
}

model MissionProofImage {
  id        String   @id @default(uuid())
  proofId   String   @map("proof_id")
  imageId   String   @map("image_id")
  createdAt DateTime @default(now()) @map("created_at")

  proof MissionProof @relation(fields: [proofId], references: [id], onDelete: Cascade)
  image Media        @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([proofId])
  @@map("delivery_proof_images")
}

model Advertisement {
  id            String              @id @default(uuid())
  type          AdvertisementType   @default(DELIVERY)
  status        AdvertisementStatus @default(OPEN)
  price         Decimal             @default(0)
  maxWeight     Decimal             @default(0) @map("max_weight") @db.Decimal(7, 3)
  weight        Decimal             @default(0) @map("weight") @db.Decimal(7, 3)
  destinationId String              @map("destination_id")
  departureId   String              @map("departure_id")
  authorId      String              @map("author_id")
  departureDate DateTime?           @map("departure_date")
  arrivalDate   DateTime            @map("arrival_date")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  author        User           @relation(fields: [authorId], references: [id])
  destination   Address        @relation("destination", fields: [destinationId], references: [id])
  departure     Address        @relation("departure", fields: [departureId], references: [id])
  missions      Mission[]
  conversations Conversation[]

  @@index([type, status])
  @@index([authorId])
  @@index([arrivalDate])
  @@map("advertisements")
}

model Transaction {
  id                   String            @id @default(uuid())
  amount               Decimal
  method               TransactionMethod @default(CASH) @map("transaction_method")
  status               TransactionStatus @default(PENDING)
  missionId            String            @unique @map("mission_id")
  transactionReference String?           @unique @map("transaction_reference")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  mission Mission @relation(fields: [missionId], references: [id])

  @@map("transactions")
}

model Conversation {
  id              String             @id @default(uuid())
  advertisementId String             @map("advertisement_id")
  shipperId       String
  carrierId       String
  missionId       String?            @map("mission_id")
  status          ConversationStatus @default(ACTIVE)
  lastMessageAt   DateTime?          @map("last_message_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mission       Mission?      @relation(fields: [missionId], references: [id])
  advertisement Advertisement @relation(fields: [advertisementId], references: [id])
  messages      Message[]
  shipper       User          @relation("shipper", fields: [shipperId], references: [id])
  carrier       User          @relation("carrier", fields: [carrierId], references: [id])

  @@unique([advertisementId, shipperId, carrierId])
  @@map("conversations")
}

enum MessageType {
  MEDIA @map("media")
  OFFER @map("offer")
  TEXT  @map("text")
}

model Message {
  id             String      @id @default(uuid())
  content        String?
  conversationId String      @map("conversation_id")
  type           MessageType @default(TEXT)
  authorId       String      @map("author_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  conversation Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User           @relation("sender", fields: [authorId], references: [id])
  medias       MessageMedia[]
  offer        MessageOffer?

  @@map("messages")
}

model MessageMedia {
  messageId String
  mediaId   String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id])

  @@id([messageId, mediaId])
  @@map("message_medias")
}

model MessageOffer {
  id        String             @id
  price     Decimal
  weight    Decimal            @default(0)
  missionId String?            @map("mission_id")
  status    MessageOfferStatus @default(PENDING)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  mission Mission? @relation(fields: [missionId], references: [id])
  message Message  @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("message_offers")
}

// ─── UX Personalization ───────────────────────────────────────────────────────

model UserPreferences {
  userId      String  @id @map("user_id")
  notifySms   Boolean @default(true) @map("notify_sms")
  notifyEmail Boolean @default(true) @map("notify_email")
  notifyPush  Boolean @default(true) @map("notify_push")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  addressId String   @map("address_id")
  label     String?

  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@unique([userId, addressId])
  @@map("saved_addresses")
}

model MissionRating {
  id        String  @id @default(uuid())
  missionId String  @map("mission_id")
  raterId   String  @map("rater_id")
  ratedId   String  @map("rated_id")
  score     Int
  comment   String?

  createdAt DateTime @default(now()) @map("created_at")

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  rater   User    @relation("RatingGiven", fields: [raterId], references: [id])
  rated   User    @relation("RatingReceived", fields: [ratedId], references: [id])

  @@unique([missionId, raterId])
  @@map("mission_ratings")
}
