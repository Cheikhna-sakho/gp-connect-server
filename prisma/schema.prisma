generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  USER  @map("user")
  ADMIN @map("admin")
  GP    @map("gp")
}

enum TransactionMethod {
  CASH        @map("cash")
  CREDIT_CARD @map("credit_card")
  PAYPAL      @map("paypal")
}

enum WeightUnit {
  KG @map("kg")
  G  @map("g")
}

enum TransactionStatus {
  PENDING   @map("pending")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
}

enum Currency {
  XOF @map("xof")
  EUR @map("eur")
  USD @map("usd")
  GBP @map("gbp")
}

enum AdvertisementType {
  GP      @map("gp")
  MISSION @map("mission")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  advertisements Advertisement[]
  clients        Transaction[]   @relation("TransactionClient")
  transactions   Transaction[]   @relation("TransactionSeller")
  packages       Package[]

  @@map("users")
}

model Address {
  id        String   @id @default(uuid())
  street    String?
  city      String
  country   String
  zipCode   String?  @map("zip_code")
  //@SOURCE https://stackoverflow.com/questions/1196415/what-datatype-to-use-when-storing-latitude-and-longitude-data-in-sql-databases
  latitude  Decimal? @db.Decimal(8, 6)
  longitude Decimal? @db.Decimal(9, 6)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  destinations Advertisement[] @relation("destination")
  departures   Advertisement[] @relation("departure")

  @@unique([latitude, longitude])
  @@map("addresses")
}

model Package {
  id         String     @id @default(uuid())
  weight     Decimal    @default(0) @db.Decimal(7, 3)
  weighrUnit WeightUnit @default(KG) @map("weight_unit")
  ownerId    String     @map("owner_id")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  owner          User                   @relation(fields: [ownerId], references: [id])
  advertisements AdvertisementPackage[]
  transaction    Transaction?

  @@map("packages")
}

model AdvertisementPackage {
  id              String   @id @default(uuid())
  packageId       String   @map("package_id")
  advertisementId String   @map("advertisement_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  package       Package       @relation(fields: [packageId], references: [id])
  advertisement Advertisement @relation(fields: [advertisementId], references: [id])

  @@map("advertisement_packages")
}

model Advertisement {
  id            String            @id @default(uuid())
  title         String?
  description   String?
  type          AdvertisementType @default(GP)
  price         Decimal           @default(0)
  currency      Currency          @default(EUR)
  destinationId String            @map("destination_id")
  departureId   String            @map("departure_id")
  authorId      String            @map("author_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  author       User                   @relation(fields: [authorId], references: [id])
  transactions Transaction[]
  destination  Address                @relation("destination", fields: [destinationId], references: [id])
  departure    Address                @relation("departure", fields: [departureId], references: [id])
  packages     AdvertisementPackage[]

  @@map("advertisements")
}

model Transaction {
  id                   String            @id @default(uuid())
  amount               Decimal
  method               TransactionMethod @map("transaction_method")
  status               TransactionStatus @default(PENDING)
  clientId             String            @map("client_id")
  sellerId             String            @map("seller_id")
  advertisementId      String            @map("advertisement_id")
  packageId            String            @unique @map("package_id")
  transactionReference String?           @unique @map("transaction_reference")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  advertisement Advertisement @relation(fields: [advertisementId], references: [id])
  package       Package       @relation(fields: [packageId], references: [id])
  client        User          @relation("TransactionClient", fields: [clientId], references: [id])
  seller        User          @relation("TransactionSeller", fields: [sellerId], references: [id])

  @@map("transactions")
}

